# Resend API key — required for contact form email delivery
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Destination email address for contact form submissions
# Defaults to hello@e5labs.com if not set
RESEND_TO_EMAIL=hello@e5labs.com

# Sender address for contact form emails (must be a Resend-verified domain)
# The default uses Resend's sandbox domain which only sends to the account owner.
# For production, set this to a verified domain e.g. "E5Labs Contact <hello@e5labs.com>"
RESEND_FROM_EMAIL=E5Labs Contact <onboarding@resend.dev>